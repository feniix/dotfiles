#!/bin/bash
#
# macOS System Preferences Configuration
# Targeted at macOS 14+ (Sonoma, Sequoia, Tahoe) on Apple Silicon
#
# Originally inspired by @mathiasbynens
# https://github.com/mathiasbynens/dotfiles/blob/master/.osx
#
# Usage:
#   ./osx-defaults              Apply all settings
#   ./osx-defaults --dry-run    Show what would be changed without applying
#   ./osx-defaults --only dock,finder   Apply specific sections only
#   ./osx-defaults --backup     Save current defaults to a file

set -e

DRY_RUN=false
ONLY_SECTIONS=""
BACKUP_ONLY=false

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --only)
      ONLY_SECTIONS="$2"
      shift 2
      ;;
    --backup)
      BACKUP_ONLY=true
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [--dry-run] [--only section1,section2] [--backup]"
      echo "Sections: system,sound,energy,input,accessibility,hotcorners,finder,dock,screenshot,safari,terminal,browser,activity,appstore,privacy,bluetooth,timemachine"
      exit 1
      ;;
  esac
done

# Check if a section should run
should_run() {
  local section="$1"
  if [[ -z "$ONLY_SECTIONS" ]]; then
    return 0
  fi
  echo ",$ONLY_SECTIONS," | grep -q ",$section,"
}

# Wrapper that respects dry-run mode
run() {
  if [[ "$DRY_RUN" == true ]]; then
    echo "  [dry-run] $*"
  else
    "$@"
  fi
}

# Backup current defaults
backup_defaults() {
  local backup_dir="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles_backup"
  local backup_file="$backup_dir/defaults-$(date +%Y%m%d_%H%M%S).plist"
  mkdir -p "$backup_dir"
  echo "Saving current defaults to $backup_file..."
  defaults read > "$backup_file"
  echo "Backup saved."
}

echo "Configuring macOS $(sw_vers -productVersion) preferences..."

# Always create a backup before making changes
backup_defaults

if [[ "$BACKUP_ONLY" == true ]]; then
  echo "Backup complete. No changes applied."
  exit 0
fi

if [[ "$DRY_RUN" == true ]]; then
  echo "(Dry-run mode: no changes will be applied)"
fi

# Request sudo privileges upfront (skip in dry-run)
if [[ "$DRY_RUN" != true ]]; then
  echo "Requesting administrator privileges (for system settings)..."
  sudo -v

  # Keep sudo alive until script finishes
  while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
  SUDO_PID=$!
  trap 'kill $SUDO_PID 2>/dev/null' EXIT
fi

#====================================================================
# System-wide preferences
#====================================================================
if should_run "system"; then
  echo "Configuring system-wide preferences..."

  # Disable chime sound on boot
  run sudo nvram StartupMute=%01

  # Set standby delay to 24 hours (default is 1 hour)
  run sudo pmset -a standbydelay 86400

  # Expand save/print panels by default
  run defaults write NSGlobalDomain NSNavPanelExpandedStateForSaveMode -bool true
  run defaults write NSGlobalDomain NSNavPanelExpandedStateForSaveMode2 -bool true
  run defaults write NSGlobalDomain PMPrintingExpandedStateForPrint2 -bool true

  # Save to disk (not to iCloud) by default
  run defaults write NSGlobalDomain NSDocumentSaveNewDocumentsToCloud -bool false

  # Disable automatic capitalization, smart quotes/dashes, auto-correct, and period substitution
  run defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
  run defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
  run defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
  run defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false
  run defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
fi

#====================================================================
# Sound preferences
#====================================================================
if should_run "sound"; then
  echo "Configuring sound preferences..."

  # Set alert volume (0.5 = moderate)
  run defaults write NSGlobalDomain com.apple.sound.beep.volume -float 0.5

  # Disable feedback sound when volume is changed
  run defaults write NSGlobalDomain com.apple.sound.beep.feedback -bool false
fi

#====================================================================
# Energy saver preferences
#====================================================================
if should_run "energy"; then
  echo "Configuring energy saver preferences..."

  # Sleep the display after 15 minutes while charging
  run sudo pmset -c displaysleep 15

  # Sleep the display after 5 minutes on battery
  run sudo pmset -b displaysleep 5

  # Set machine sleep to 15 minutes on battery
  run sudo pmset -b sleep 15

  # Sleep after 78 minutes while charging
  run sudo pmset -c sleep 78
fi

#====================================================================
# Trackpad, mouse, keyboard, and input
#====================================================================
if should_run "input"; then
  echo "Configuring input devices..."

  # Enable tap to click (Trackpad)
  run defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
  run defaults -currentHost write NSGlobalDomain com.apple.mouse.tapBehavior -int 1
  run defaults write NSGlobalDomain com.apple.mouse.tapBehavior -int 1

  # Disable "natural" scrolling
  run defaults write NSGlobalDomain com.apple.swipescrolldirection -bool false

  # Set fast key repeat rate and short delay
  run defaults write NSGlobalDomain KeyRepeat -int 2
  run defaults write NSGlobalDomain InitialKeyRepeat -int 15

  # Disable press-and-hold for keys in favor of key repeat
  run defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

  # Enable full keyboard access for all controls (e.g. Tab in modal dialogs)
  run defaults write NSGlobalDomain AppleKeyboardUIMode -int 3

  # Make Fn key do nothing (prevents accidental emoji popup)
  run defaults write com.apple.HIToolbox AppleFnUsageType -int 0
fi

#====================================================================
# Accessibility preferences
#====================================================================
if should_run "accessibility"; then
  echo "Configuring accessibility preferences..."

  # Enable three finger drag
  run defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerDrag -bool true
  run defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerDrag -bool true

  # Reduce transparency
  run defaults write com.apple.universalaccess reduceTransparency -bool true
fi

#====================================================================
# Hot corners
#====================================================================
if should_run "hotcorners"; then
  echo "Configuring hot corners..."

  # Possible values:
  #  0: no-op        2: Mission Control   3: Application Windows
  #  4: Desktop      5: Screen Saver      6: Disable Screen Saver
  # 10: Display Sleep  11: Launchpad  12: Notification Center  13: Lock Screen

  # Top left     -> Mission Control
  run defaults write com.apple.dock wvous-tl-corner -int 2
  run defaults write com.apple.dock wvous-tl-modifier -int 0

  # Top right    -> Desktop
  run defaults write com.apple.dock wvous-tr-corner -int 4
  run defaults write com.apple.dock wvous-tr-modifier -int 0

  # Bottom left  -> Screen Saver
  run defaults write com.apple.dock wvous-bl-corner -int 5
  run defaults write com.apple.dock wvous-bl-modifier -int 0

  # Bottom right -> Lock Screen
  run defaults write com.apple.dock wvous-br-corner -int 13
  run defaults write com.apple.dock wvous-br-modifier -int 0
fi

#====================================================================
# Finder preferences
#====================================================================
if should_run "finder"; then
  echo "Configuring Finder preferences..."

  # Allow quitting Finder via Cmd+Q
  run defaults write com.apple.finder QuitMenuItem -bool true

  # Show all filename extensions
  run defaults write NSGlobalDomain AppleShowAllExtensions -bool true

  # Show hidden files (dotfiles)
  run defaults write com.apple.finder AppleShowAllFiles -bool true

  # Show path bar and status bar
  run defaults write com.apple.finder ShowPathbar -bool true
  run defaults write com.apple.finder ShowStatusBar -bool true

  # Display full POSIX path as Finder window title
  run defaults write com.apple.finder _FXShowPosixPathInTitle -bool true

  # Always open in list view
  run defaults write com.apple.finder FXPreferredViewStyle -string "Nlsv"

  # Search results in list view too
  run defaults write com.apple.finder SearchRecentsSavedViewStyle -string "Nlsv"

  # Keep folders on top when sorting by name
  run defaults write com.apple.finder _FXSortFoldersFirst -bool true

  # Disable the warning when changing a file extension
  run defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false

  # New Finder windows open Home instead of Recents
  run defaults write com.apple.finder NewWindowTarget -string "PfHm"

  # Show external drives and removable media on the desktop
  run defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool true
  run defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool true

  # Avoid creating .DS_Store files on network or USB volumes
  run defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
  run defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true

  # Enable AirDrop over Ethernet
  run defaults write com.apple.NetworkBrowser BrowseAllInterfaces -bool true

  # Auto-delete Trash items after 30 days
  run defaults write com.apple.finder FXRemoveOldTrashItems -bool true

  # Show the ~/Library folder
  run chflags nohidden ~/Library

  # Show the /Volumes folder
  run sudo chflags nohidden /Volumes
fi

#====================================================================
# Dock preferences
#====================================================================
if should_run "dock"; then
  echo "Configuring Dock preferences..."

  # Set the icon size of Dock items
  run defaults write com.apple.dock tilesize -int 42

  # Change minimize/maximize window effect to scale
  run defaults write com.apple.dock mineffect -string "scale"

  # Minimize windows into their application icon
  run defaults write com.apple.dock minimize-to-application -bool true

  # Remove the auto-hiding Dock delay
  run defaults write com.apple.dock autohide-delay -float 0

  # Speed up the animation when hiding/showing the Dock
  run defaults write com.apple.dock autohide-time-modifier -float 0.15

  # Don't automatically rearrange Spaces based on most recent use
  run defaults write com.apple.dock mru-spaces -bool false

  # Auto-hide the Dock
  run defaults write com.apple.dock autohide -bool true

  # Make Dock icons of hidden applications translucent
  run defaults write com.apple.dock showhidden -bool true

  # Don't show recent applications in Dock
  run defaults write com.apple.dock show-recents -bool false

  # Speed up Mission Control animations
  run defaults write com.apple.dock expose-animation-duration -float 0.15

  # Disable click-on-wallpaper to show desktop (macOS 14+)
  run defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -bool false
fi

#====================================================================
# Screenshot preferences
#====================================================================
if should_run "screenshot"; then
  echo "Configuring screenshot preferences..."

  # Save screenshots in PNG format
  run defaults write com.apple.screencapture type -string "png"

  # Save screenshots to Downloads folder
  run defaults write com.apple.screencapture location -string "${HOME}/Downloads"

  # Include date in screenshot filenames
  run defaults write com.apple.screencapture include-date -bool true

  # Disable shadow in screenshots
  run defaults write com.apple.screencapture disable-shadow -bool true
fi

#====================================================================
# Safari preferences
#====================================================================
if should_run "safari"; then
  echo "Configuring Safari preferences..."

  # Don't send search queries to Apple
  run defaults write com.apple.Safari UniversalSearchEnabled -bool false
  run defaults write com.apple.Safari SuppressSearchSuggestions -bool true

  # Make search banners default to Contains instead of Starts With
  run defaults write com.apple.Safari FindOnPageMatchesWordStartsOnly -bool false

  # Enable the Develop menu
  run defaults write com.apple.Safari IncludeDevelopMenu -bool true
fi

#====================================================================
# Terminal preferences
#====================================================================
if should_run "terminal"; then
  echo "Configuring Terminal preferences..."

  # Enable Secure Keyboard Entry in Terminal.app
  run defaults write com.apple.terminal SecureKeyboardEntry -bool true
fi

#====================================================================
# Browser preferences
#====================================================================
if should_run "browser"; then
  echo "Configuring browser preferences..."

  # Disable swipe navigation in Chrome
  run defaults write com.google.Chrome AppleEnableSwipeNavigateWithScrolls -bool false

  # Use the system print dialog in Chrome
  run defaults write com.google.Chrome DisablePrintPreview -bool true

  # Expand the print dialog by default in Chrome
  run defaults write com.google.Chrome PMPrintingExpandedStateForPrint2 -bool true
fi

#====================================================================
# Activity Monitor preferences
#====================================================================
if should_run "activity"; then
  echo "Configuring Activity Monitor preferences..."

  # Show the main window when launching
  run defaults write com.apple.ActivityMonitor OpenMainWindow -bool true

  # Visualize CPU usage in the Dock icon
  run defaults write com.apple.ActivityMonitor IconType -int 5

  # Show all processes
  run defaults write com.apple.ActivityMonitor ShowCategory -int 0

  # Sort by CPU usage
  run defaults write com.apple.ActivityMonitor SortColumn -string "CPUUsage"
  run defaults write com.apple.ActivityMonitor SortDirection -int 0

  # Update frequency: every 2 seconds
  run defaults write com.apple.ActivityMonitor UpdatePeriod -int 2
fi

#====================================================================
# App Store preferences
#====================================================================
if should_run "appstore"; then
  echo "Configuring App Store preferences..."

  # Enable automatic updates
  run defaults write com.apple.commerce AutoUpdate -bool true

  # Check for software updates daily
  run defaults write com.apple.SoftwareUpdate ScheduleFrequency -int 1

  # Download newly available updates in background
  run defaults write com.apple.SoftwareUpdate AutomaticDownload -int 1

  # Install system data files and security updates
  run defaults write com.apple.SoftwareUpdate CriticalUpdateInstall -int 1
fi

#====================================================================
# Privacy
#====================================================================
if should_run "privacy"; then
  echo "Configuring privacy preferences..."

  # Disable personalized ads
  run defaults write com.apple.AdLib allowApplePersonalizedAdvertising -bool false
fi

#====================================================================
# Bluetooth
#====================================================================
if should_run "bluetooth"; then
  echo "Configuring Bluetooth preferences..."

  # Improve Bluetooth audio quality (higher min bitpool)
  run defaults write com.apple.BluetoothAudioAgent "Apple Bitpool Min (editable)" -int 40
fi

#====================================================================
# Time Machine
#====================================================================
if should_run "timemachine"; then
  echo "Configuring Time Machine preferences..."

  # Don't prompt to use new disks for backup
  run defaults write com.apple.TimeMachine DoNotOfferNewDisksForBackup -bool true
fi

#====================================================================
# Restart affected applications
#====================================================================
if [[ "$DRY_RUN" != true ]]; then
  echo "Restarting affected applications..."

  for app in "Activity Monitor" "cfprefsd" "Dock" "Finder" "Safari" "SystemUIServer"; do
    killall "${app}" &> /dev/null || true
  done

  # Verify key settings
  echo ""
  echo "Verifying key settings..."
  verify_pass=0
  verify_fail=0

  check_setting() {
    local domain="$1"
    local key="$2"
    local expected="$3"
    local label="$4"
    local actual
    actual=$(defaults read "$domain" "$key" 2>/dev/null || echo "UNSET")
    if [[ "$actual" == "$expected" ]]; then
      echo "  OK: $label"
      verify_pass=$((verify_pass + 1))
    else
      echo "  FAILED: $label (expected $expected, got $actual)"
      verify_fail=$((verify_fail + 1))
    fi
  }

  check_setting "com.apple.dock" "autohide" "1" "Dock autohide"
  check_setting "com.apple.dock" "show-recents" "0" "Dock hide recents"
  check_setting "com.apple.finder" "AppleShowAllFiles" "1" "Finder show hidden files"
  check_setting "com.apple.finder" "ShowPathbar" "1" "Finder path bar"
  check_setting "NSGlobalDomain" "ApplePressAndHoldEnabled" "0" "Key repeat enabled"
  check_setting "com.apple.AdLib" "allowApplePersonalizedAdvertising" "0" "Personalized ads disabled"

  echo ""
  echo "Verified: $verify_pass passed, $verify_fail failed"
fi

echo "Done! Some changes require a logout/restart to take effect."
