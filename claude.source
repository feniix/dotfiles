kimi() {
    (
        export ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
        export ANTHROPIC_AUTH_TOKEN=$KIMI_API_KEY
        export ENABLE_TOOL_SEARCH=false
        export API_TIMEOUT_MS=3000000
        export ANTHROPIC_DEFAULT_HAIKU_MODEL=k2p5
        export ANTHROPIC_DEFAULT_SONNET_MODELw=k2p5
        export ANTHROPIC_DEFAULT_OPUS_MODELw=k2p5
        export ANTHROPIC_MODEL=k2p5
        claude "$@"
    )
}

zai() {
    (
        export ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
        export ANTHROPIC_AUTH_TOKEN=$Z_API_KEY
        export ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7
        export ANTHROPIC_DEFAULT_SONNET_MODELw=glm-5
        export ANTHROPIC_DEFAULT_OPUS_MODELw=glm-5
        export ANTHROPIC_MODEL=glm-5
        export API_TIMEOUT_MS=3000000
        claude "$@"
    )
}

dseek() {
    (
        export ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
        export ANTHROPIC_AUTH_TOKEN=${DEEPSEEK_API_KEY}
        export ANTHROPIC_MODEL=deepseek-chat
        export ANTHROPIC_SMALL_FAST_MODEL=deepseek-chat
        export API_TIMEOUT_MS=3000000
        claude "$@"
    )
}

ccmm() {
    (
        export ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
        export ANTHROPIC_AUTH_TOKEN=$MINIMAX_API_KEY
        export API_TIMEOUT_MS=3000000
        export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
        # MiniMax-M2.5-HighSpeed
        export ANTHROPIC_MODEL=MiniMax-M2.7-HighSpeed
        export ANTHROPIC_SMALL_FAST_MODEL=MiniMax-M2.7-HighSpeed
        export ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7-HighSpeed
        export ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M2.7-HighSpeed
        export ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7-HighSpeed
        claude "$@"
    )
}
