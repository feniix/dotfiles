[user]
  name = Sebastian Otaegui
  email = feniix@gmail.com
	signingkey = ~/.ssh/id_ed25519

[credential]
  helper = osxkeychain

[push]
  default = current

[alias]
  s = status
  ci = commit
  br = branch
  co = checkout
  d = diff
  lg = log
  l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  ld = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit -p
  append = commit --amend -C HEAD

[core]
  autocrlf = input
  excludesfile = ~/.config/git/ignore
  # deals with umlaits
  quotepath = false
  pager = diff-so-fancy | less --tabs=4 -RFX
  ignorecase = false

[rebase]
  autosquash = true

[branch]
  autosetupmerge = always

[diff]
  renames = copies
  mnemonicprefix = true

[color]
  ui = true

[color "branch"]
  current = yellow black
  local = yellow
  remote = magenta

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red reverse
  new = green reverse
  whitespace = white reverse

[color "status"]
  added = green
  changed = yellow
  untracked = cyan reverse
  branch = magenta

[github]
  user = feniix

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[pager]
  log = diff-so-fancy | less
  show = diff-so-fancy | less
  diff = diff-so-fancy | less

[interactive]
  added = green
  changed = yellow
  untracked = cyan reverse
  branch = magenta

[http "https://gopkg.in"]
  followRedirects = true

[commit]
  gpgsign = true

[diff "sopsdiffer"]
  textconv = sops -d

[pull]
  rebase = false

[init]
  defaultBranch = main

[url "git@github-gatx:GATX-Corp/"]
  insteadOf = https://github.com/GATX-Corp/

[url "git@github-gatx:GATX-Corp/"]
  insteadOf = git@github.com:GATX-Corp/

[url "git@github.com:feniix/"]
  insteadOf = https://github.com/feniix/

[url "git@github.com:spantree/"]
  insteadOf = https://github.com/spantree/
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[gpg]
	format = ssh
